{
  "name": "ne6dmcp",
  "version": "0.1.0",
  "description": "MCP server exposing a USB-attached Nord Electro 6D as natural-language-controllable MCP tools",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ne6dmcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-schema.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "doctor": "tsx scripts/doctor.ts",
    "melody-test": "tsx scripts/melody-test.ts",
    "listen": "tsx scripts/listen.ts",
    "smoke": "npm run build && tsx scripts/smoke.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build-schema": "tsx scripts/build-schema.ts"
  },
  "dependencies": {
    "@julusian/midi": "^3.1.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
